{
    "compilerOptions": {
      "jsx": "react-jsx", // Adicione esta linha para suportar JSX
      "target": "ES6",
      "module": "ES6",
      "moduleResolution": "node",
      "esModuleInterop": true,
      "skipLibCheck": true,
      "strict": true,
      "baseUrl": ".",
      "paths": {
        "@/*": ["src/*"],
        "@Components/*": ["src/Components/*"]
      }
    },
    "include": ["src"]
  }